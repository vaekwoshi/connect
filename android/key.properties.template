# 릴리스 서명 키 설정 — 이 파일을 복사해 android/key.properties 로 저장하고 값을 채우세요.
# (key.properties 와 .jks/.keystore 는 .gitignore 로 보호됨. 절대 커밋·공유 금지)
#
# 키스토어 생성(JDK의 keytool 필요):
#   keytool -genkey -v -keystore %USERPROFILE%\sekkeul-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias sekkeul
#
storePassword=여기에_키스토어_비밀번호
keyPassword=여기에_키_비밀번호
keyAlias=sekkeul
storeFile=C:/Users/사용자명/sekkeul-release.jks
